---
import Layout from '../layouts/Layout.astro';

const leaders = [
  { img: '/images/leaders/janine.jpg', name: 'Janine Vos', role: 'Chief HR Officer', org: 'Rabobank Groep (Finance)' },
  { img: '/images/leaders/bas.jpg', name: 'Bas van der Veldt', role: 'CEO en Eindbaas', org: 'AFAS Software (IT)' },
  { img: '/images/leaders/astrid.jpg', name: 'Astrid Posthouwer', role: 'Voorzitter RVB', org: 'Meander Medisch Centrum (Ziekenhuis Zorg)' },
  { img: '/images/leaders/janhol.jpg', name: 'Jan Hol', role: 'Voorzitter CVB', org: 'Christelijke Hogeschool Ede (Onderwijs)' },
  { img: '/images/leaders/janny.jpg', name: 'Janny Bakker', role: 'CEO Movisie (Sociaal Domein)', org: 'CDA Senator in de Eerste Kamer (Politiek)' },
  { img: '/images/leaders/theo.jpg', name: 'Theo den Hertog', role: 'Voorzitter RVB', org: 'RIBW Overijssel (GGZ)' },
  { img: '/images/leaders/shequita.jpg', name: 'Shequita Kalloe', role: 'Lid RVB', org: 'Argos Zorggroep (Ouderenzorg)' },
  { img: '/images/leaders/didier.jpg', name: 'Didier Dohmen', role: 'Interim Bestuurder in Zorg & Onderwijs', org: 'AxionContinu | Mooi Sociaal' },
];
---

<Layout
  title="Joyfulness Coöperatie"
  description="Joyfulness — coöperatie voor de evolutie van leiderschap en organiseren. Binnenkort: een nieuw boek over de innerlijke reis naar het volgende paradigma."
>
  <header class="site" id="site-header">
    <a href="/" class="logo-link">
      <img src="/images/logo-horizontaal.png" alt="Joyfulness Coöperatie" class="site-logo" />
    </a>
    <button class="nav-toggle" aria-label="Menu openen" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>
    <nav class="site-nav" id="site-nav">
      <a href="/blog/">Blog</a>
      <a href="/seizoenplotter/">Seizoenplotter</a>
      <a href="/quickscan-verticale-leiderschapsontwikkeling/">Quickscan Leiderschap</a>
      <a href="/quickscan-organische-groei/">Quickscan Organische Groei</a>
      <a href="/#contact">Contact</a>
    </nav>
  </header>

  <main class="wrap">

    <section class="hero">
      <h1>Op reis naar het volgende paradigma in leiderschap en organiseren.</h1>
      <p class="lead">
        Joyfulness is een coöperatie die zich inzet voor de evolutie van leiderschap en
        organiseren. We brengen leiders in een bewustzijnsontwikkeling, zodat zij de spanning
        kunnen dragen die een verandering van tijdperk en transformatie van ze vraagt. Vanuit
        <em>inzicht</em>, <em>authenticiteit</em> en <em>bezieling</em>.
      </p>
    </section>

    <div class="dots" aria-hidden="true">
      <span style="background:#e31e3c"></span>
      <span style="background:#f39c12"></span>
      <span style="background:#e3d44a"></span>
      <span style="background:#5bb94e"></span>
      <span style="background:#1b5e82"></span>
      <span style="background:#ec008c"></span>
    </div>

    <section class="logos">
      <div class="card-sage">
        <div class="logos-head">
          <h2>Wij werken voor</h2>
        </div>
        <div class="logo-grid">
          <img src="/images/logo-sevagram.jpeg" alt="Sevagram" />
          <img src="/images/logo-noorderbreedte.png" alt="Noorderbreedte" />
          <img src="/images/logo-eldemaasduinen.png" alt="Zorggroep Elde Maasduinen" />
          <img src="/images/logo-liemerije.png" alt="Liemerije" />
          <img src="/images/logo-fundatie.png" alt="Museum de Fundatie" />
          <img src="/images/logo-domusvaluas.png" alt="Domus Valuas" />
          <img src="/images/logo-wijzijnjong.png" alt="Wij zijn JONG" />
        </div>
      </div>
    </section>

    <section class="book-section">
      <div class="book-grid">
        <div class="img-col">
          <img src="/images/mood-fern.jpg" alt="" style="object-position: center 75%;" />
        </div>
        <div class="text-col">
          <p class="kicker">Binnenkort</p>
          <h2>Een nieuw boek</h2>
          <p>
            Dit najaar verschijnt een nieuw boek over de evolutie van leiderschap en
            organisaties — de innerlijke reis naar het volgende paradigma in leiderschap en
            organiseren. De titel maken we binnenkort bekend.
          </p>
          <span class="badge">Verwachte verschijning: <strong>september / oktober 2026</strong></span>
        </div>
      </div>
    </section>

    <section class="book-section is-plain">
      <div class="book-grid reverse">
        <div class="img-col" style="height:auto; overflow:hidden; border-radius:14px;">
          <img src="/images/mood-thorn.jpg" alt="" style="height:auto; object-fit:contain; border-radius:14px;" />
        </div>
        <div class="text-col">
          <h2 class="heading-sans">Wanneer leiderschap begint te schuren</h2>
          <p>
            We leven in een tijdperk van ongekende versnelling en voortdurende verandering.
            Traditionele benaderingen van leiderschap, geworteld in een mechanistisch wereldbeeld
            van controle en voorspelbaarheid, dragen niet langer bij aan een gezonde, duurzame
            ontwikkeling van organisaties en de maatschappelijke behoefte. Leiders ervaren de
            frictie. Het groeiende ongemak. De worsteling met vastgeroeste patronen en een
            sluimerend gevoel van uitputting. Leiderschap voelt niet langer vanzelfsprekend.
            Veranderingen blijven steken. Mensen haken af of beschermen zich achter regels en
            procedures. Jij voelt dat het anders moet. Maar elke volgende aanpak lijkt slechts
            een nieuwe variant van hetzelfde patroon. Er wordt veel gesproken over cultuur, maar
            weinig werkelijk geraakt. Je hebt kennis, ervaring en verantwoordelijkheid. En toch is
            er dat knagende gevoel. Je weet dat er een andere richting nodig is, maar niet hoe die
            eruitziet. Het oude werkt niet meer. Het nieuwe laat zich nog niet zien, en laat zich
            zeker niet afdwingen.
          </p>
        </div>
      </div>
    </section>

    <section class="doorkijkje">
      <div class="card-dark doorkijkje-grid">
        <div class="doorkijkje-img">
          <img src="/images/doorkijkje-janine.jpg" alt="Citaat van Janine Vos uit het boek" class="zoomable" title="Klik om te vergroten" />
          <button class="zoom-hint" aria-label="Vergroten">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M8 11h6"/></svg>
          </button>
        </div>
        <!-- Lightbox -->
        <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Vergroot citaat">
          <button class="lightbox-close" aria-label="Sluiten">&#x2715;</button>
          <img src="/images/doorkijkje-janine.jpg" alt="Citaat van Janine Vos uit het boek" />
        </div>
        <div>
          <p class="kicker">Een doorkijkje</p>
          <h2>Een stem uit het boek</h2>
          <p>
            Een glimp van de interviews met leiders die hun reis met ons deelden — open,
            kwetsbare gesprekken die het boek voeden.
          </p>
        </div>
      </div>
    </section>

    <section class="leaders">
      <div class="card-cream">
        <p class="kicker" style="text-align:center;">Intro's geïnterviewde leiders</p>
        <h2 style="text-align:center; max-width:680px; margin:0 auto;">De leiders die je in ons boek tegenkomt</h2>
        <p style="text-align:center; max-width:640px; margin:0.9rem auto 0;">
          We interviewden leiders uit de Zorg, Onderwijs, Politiek, Sociaal domein, GGZ, IT en
          Finance — open, kwetsbare gesprekken die het boek voeden en jou als lezer de visie van
          dit boek laten proeven.
        </p>
        <div class="leaders-grid">
          {leaders.map((l) => (
            <div class="leader">
              <div class="leader-avatar"><img src={l.img} alt={l.name} /></div>
              <h3>{l.name}</h3>
              <p class="leader-role">{l.role}</p>
              <p class="leader-org">{l.org}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="brengen">
      <div class="brengen-head">
        <p class="kicker">Wat we brengen</p>
        <h2>Drie wegen naar het volgende paradigma</h2>
      </div>
      <div class="cards">
        <div class="card">
          <span class="num">01</span>
          <h3>Verticale leiderschapsontwikkeling</h3>
          <p>We ontwikkelen het bewustzijnsniveau van leiders, zodat zij kunnen sturen op de
          complexiteit en onvoorspelbaarheid die deze tijd vraagt — voorbij kennis en kunde, naar
          wie je bent als leider.</p>
          <a class="card-link" href="/quickscan-verticale-leiderschapsontwikkeling/">Doe de Quickscan →</a>
        </div>
        <div class="card">
          <span class="num">02</span>
          <h3>Natuurlijk innoveren voor teams en organisaties</h3>
          <p>Innovatie die niet wordt afgedwongen, maar ontstaat zoals de natuur dat doet: vanuit
          een echte verbinding, afgestemd op het huidige seizoen en wat dat van ons vraagt. Soms
          juist vertragen of juist versnellen. Wij begeleiden teams en organisaties in dat
          natuurlijke ontwikkelproces.</p>
          <a class="card-link" href="/quickscan-organische-groei/">Doe de Quickscan →</a>
        </div>
        <div class="card">
          <span class="num">03</span>
          <h3>Ontwikkelen vanuit de onderstroom</h3>
          <p>Ieder organisatiecultuur wordt gevoed met de onderstroom van overtuigingen,
          opgebouwde kracht tot angst, ondersteund door verhalen, helden en schurken. Dit creëert
          soms bloei, soms juist verwelking en ongewenste herhalende patronen. Wij maken de
          onderstroom voelbaar en bespreekbaar, zodat blijvende verandering vanuit de kern kan
          ontstaan.</p>
        </div>
      </div>
    </section>

    <section class="who">
      <div class="card-sage who-grid">
        <div>
          <img src="/images/menno-johan.jpg" alt="Johan Spaans en Menno Braakman" />
          <div class="who-names">
            <a href="https://nl.linkedin.com/in/johan-spaans-681781143" target="_blank" rel="noopener">Johan Spaans</a>
            &amp;
            <a href="https://www.linkedin.com/in/mennobraakman" target="_blank" rel="noopener">Menno Braakman</a>
          </div>
        </div>
        <div>
          <p class="kicker">Wie zijn wij</p>
          <h2>Johan &amp; Menno</h2>
          <p>
            Onze levensreizen lijken op het eerste gezicht verschillend, maar delen een
            gemeenschappelijke kern: het inzicht dat ware leiderschapstransformatie niet ontstaat
            door <em>harder te werken</em> of <em>meer kennis te verzamelen</em>, maar door
            <em>dieper naar binnen te gaan</em>.
          </p>
          <p style="margin-top:1rem;">
            Vanuit die overtuiging begeleiden we leiders, teams en organisaties die de stap willen
            zetten van een mechanistisch perspectief naar het organische, natuurlijke en bezielde
            — het pad van innerlijke transformatie dat we samen, met een gedeeld kompas, blijven
            bewandelen.
          </p>
        </div>
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="card-cream contact-grid">
        <div>
          <p class="kicker">Contact</p>
          <h2>Neem contact op</h2>
          <p style="margin-top:0.8rem;">
            Heb je een vraag, wil je sparren over jouw organisatie of meer weten over het boek?
            Stuur ons een bericht.
          </p>
          <form id="contact-form">
            <input type="text" name="naam" placeholder="Naam" required />
            <input type="email" name="email" placeholder="E-mailadres" required />
            <textarea name="bericht" placeholder="Je bericht" rows="4" required></textarea>
            <button type="submit">Versturen</button>
          </form>
        </div>
        <div class="contact-call">
          <p class="kicker">Of bel direct</p>
          <a class="call-btn" href="tel:+31617381354">Bel ons</a>
        </div>
      </div>
    </section>

  </main>

  <footer class="site">
    <p>&copy; {new Date().getFullYear()} Joyfulness Coöperatie U.A.</p>
    <div class="social-links">
      <a href="https://www.linkedin.com/company/joyfulness-worldwide-cooperative/" target="_blank" rel="noopener" aria-label="Joyfulness op LinkedIn">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z"/></svg>
      </a>
      <a href="https://www.instagram.com/joyfulness.worldwide/" target="_blank" rel="noopener" aria-label="Joyfulness op Instagram">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.24 2.22.41.56.21.96.47 1.38.89.42.42.68.82.89 1.38.17.42.36 1.05.41 2.22.06 1.27.07 1.64.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.24 1.8-.41 2.22-.21.56-.47.96-.89 1.38-.42.42-.82.68-1.38.89-.42.17-1.05.36-2.22.41-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.24-2.22-.41a3.74 3.74 0 0 1-1.38-.89 3.74 3.74 0 0 1-.89-1.38c-.17-.42-.36-1.05-.41-2.22-.06-1.27-.07-1.64-.07-4.85s.01-3.58.07-4.85c.05-1.17.24-1.8.41-2.22.21-.56.47-.96.89-1.38.42-.42.82-.68 1.38-.89.42-.17 1.05-.36 2.22-.41 1.27-.06 1.64-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.39A5.85 5.85 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.39 2.13.67.67 1.34 1.08 2.13 1.39.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.31 1.46-.72 2.13-1.39.67-.67 1.08-1.34 1.39-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.85 5.85 0 0 0-1.39-2.13A5.85 5.85 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 1 0 12 18.16 6.16 6.16 0 0 0 12 5.84zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.41-10.97a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0z"/></svg>
      </a>
    </div>
  </footer>

  <style>
    .wrap { max-width: var(--max-width); margin: 0 auto; padding: 0 1.75rem; }
    .kicker {
      font-family: 'LibertadBold', sans-serif;
      font-weight: 400;
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green);
      margin: 0 0 0.9rem;
    }

    /* header */
    header.site {
      display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
      padding: 2.4rem 1.75rem 1.2rem; max-width: var(--max-width); margin: 0 auto;
      position: relative;
    }
    .logo-link { display: flex; align-items: center; flex-shrink: 0; text-decoration: none; }
    .site-logo { height: 80px; width: auto; display: block; }
    @media (max-width: 760px) { .site-logo { height: 60px; } }
    .site-nav {
      margin-left: auto; display: flex; align-items: center; gap: 1.8rem;
    }
    .site-nav a {
      font-family: 'Libertad', sans-serif; font-weight: 600; font-size: 0.82rem;
      letter-spacing: 0.02em; color: var(--text); text-decoration: none;
      border-bottom: 1px solid transparent; padding-bottom: 2px; transition: color 0.15s, border-color 0.15s;
    }
    .site-nav a:hover { color: var(--green-dark); border-color: var(--green); }

    /* hamburger */
    .nav-toggle {
      display: none; margin-left: auto; flex-direction: column; justify-content: center;
      gap: 5px; background: none; border: none; cursor: pointer; padding: 4px 0; width: 28px;
    }
    .nav-toggle span {
      display: block; height: 2px; width: 100%; background: var(--text);
      border-radius: 2px; transition: transform 0.22s, opacity 0.22s;
    }
    header.site.nav-open .nav-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    header.site.nav-open .nav-toggle span:nth-child(2) { opacity: 0; }
    header.site.nav-open .nav-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    @media (max-width: 760px) {
      .nav-toggle { display: flex; }
      .site-nav {
        display: none; width: 100%; flex-direction: column; align-items: flex-start;
        gap: 0; margin-left: 0; padding: 0.4rem 0 0.8rem; border-top: 1px solid var(--border);
      }
      .site-nav a { padding: 0.7rem 0; font-size: 0.95rem; width: 100%; border-bottom: none; }
      header.site.nav-open .site-nav { display: flex; }
    }

    /* dot divider */
    .dots { display:flex; gap:0.5rem; justify-content:center; margin: 3.2rem 0; }
    .dots span { width:9px; height:9px; border-radius:50%; display:inline-block; }

    section { padding: 3.2rem 0; }

    /* hero */
    .hero { text-align:center; }
    .hero h1 { font-size: clamp(2rem, 4.4vw, 2.9rem); max-width: 820px; margin: 0 auto; }
    .hero .lead { font-size: 1.12rem; max-width: 660px; margin: 1.4rem auto 0; }

    /* section background cards */
    .card-sage, .card-dark, .card-cream { border-radius: 18px; padding: 3rem 2.8rem; }
    .card-sage { background: var(--bg-sage); }
    .card-dark { background: var(--bg-dark); }
    .card-cream { background: var(--bg-soft); }
    .card-dark .kicker { color: #cfe0c4; }
    .card-dark h2, .card-dark h3 { color: #ffffff; }
    .card-dark p { color: #d9e2d2; }

    /* contact */
    .contact-grid { display:grid; grid-template-columns: 1.4fr 1fr; gap: 2.6rem; align-items:start; }
    #contact-form { display:flex; flex-direction:column; gap: 0.8rem; margin-top: 1.4rem; }
    #contact-form input, #contact-form textarea {
      font-family: 'Libertad', sans-serif; font-size: 1rem; padding: 0.7rem 0.9rem;
      border: 1px solid var(--border); border-radius: 8px; background: #fff; color: var(--text);
      resize: vertical;
    }
    #contact-form button {
      font-family:'Jost',sans-serif; font-weight:600; text-transform:uppercase; letter-spacing:0.04em;
      font-size: 0.85rem; background: var(--green); color:#fff; border:none; border-radius: 999px;
      padding: 0.85rem 1.6rem; cursor:pointer; width: fit-content; margin-top:0.3rem;
    }
    #contact-form button:hover { background: var(--green-dark); }
    .contact-call { border-left: 1px solid var(--border); padding-left: 2.4rem; text-align:center; }
    .call-btn {
      display:inline-block; margin-top: 1.2rem; padding: 0.85rem 1.8rem;
      background: var(--green); color:#fff !important; text-decoration:none;
      border-radius: 999px; font-family:'Jost',sans-serif; font-weight:600; font-size:0.85rem;
      letter-spacing: 0.04em; text-transform: uppercase;
    }
    .call-btn:hover { background: var(--green-dark); }
    @media (max-width: 760px) {
      .contact-grid { grid-template-columns: 1fr; }
      .contact-call { border-left:none; padding-left:0; border-top:1px solid var(--border); padding-top:1.6rem; }
      #contact-form button { width: 100%; text-align: center; justify-content: center; }
      .call-btn { display: block; text-align: center; }
    }

    /* wij werken voor */
    .logos-head { text-align:center; margin-bottom: 2.6rem; }
    .logos-head h2 { font-family:'Jost',sans-serif; text-transform:uppercase; font-size:1.3rem; letter-spacing:0.04em; color: var(--green-dark); }
    .logo-grid {
      display:flex; flex-wrap:wrap; justify-content:center; align-items:center;
      gap: 2.6rem 3.6rem;
    }
    .logo-grid img {
      max-height: 72px; max-width: 190px; object-fit:contain;
      filter: grayscale(100%) opacity(0.62);
      transition: filter .2s ease;
    }
    .logo-grid img:hover { filter: none; }
    @media (max-width: 540px) {
      .logo-grid { flex-direction: column; gap: 1.6rem; }
      .logo-grid img { max-width: 170px; max-height: 60px; }
    }

    /* book section */
    .book-section { background: var(--bg-soft); border-radius: 18px; overflow:hidden; }
    .book-section.is-plain { background: transparent; border-radius: 0; }
    .book-grid { display:grid; grid-template-columns: 1fr 1.1fr; min-height: 420px; }
    .book-grid .img-col { position:relative; height: 420px; overflow:hidden; border-radius: 14px; }
    .book-grid .img-col img { width:100%; height:100%; object-fit:cover; display:block; }
    .book-grid .text-col { padding: 3rem 3.2rem; display:flex; flex-direction:column; justify-content:center; }
    .book-grid.reverse .img-col { order: 2; }
    .book-grid.reverse .text-col { order: 1; }
    .book-grid h2 { font-size: clamp(1.6rem, 3vw, 2.1rem); margin-bottom: 1.1rem; }
    .book-grid p { font-size: 1.02rem; }
    .heading-sans {
      font-family: 'Libertad', sans-serif;
      text-transform: uppercase;
      color: var(--green-dark);
      font-size: clamp(1.25rem, 2.2vw, 1.65rem);
      letter-spacing: 0.02em;
      line-height: 1.28;
      margin-bottom: 1.1rem;
    }
    .badge {
      display:inline-block; margin-top: 1.6rem; padding: 0.5rem 1rem;
      border: 1px solid var(--green); border-radius: 999px;
      font-family:'Jost',sans-serif; font-size: 0.78rem; letter-spacing:0.03em;
      color: var(--green-dark); width:fit-content;
    }
    .badge strong { color: var(--green-dark); }

    @media (max-width: 760px) {
      .book-grid { grid-template-columns: 1fr; }
      .book-grid .img-col { height: 260px; order: -1 !important; }
      .book-grid .text-col { padding: 2.2rem 1.6rem; order: 1 !important; }
    }

    /* doorkijkje */
    .doorkijkje-grid {
      display:grid; grid-template-columns: 0.85fr 1.15fr; gap: 2.8rem; align-items:center;
    }
    .doorkijkje-img { position: relative; }
    .doorkijkje-img img {
      width: 100%; display:block; border-radius: 14px;
      box-shadow: 0 18px 40px -16px rgba(0,0,0,0.5);
      cursor: zoom-in;
    }
    .zoom-hint {
      position: absolute; bottom: 10px; right: 10px;
      background: rgba(255,255,255,0.88); border: none; border-radius: 50%;
      width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: var(--green-dark); backdrop-filter: blur(4px);
      transition: background 0.15s;
    }
    .zoom-hint:hover { background: #fff; }
    /* Lightbox */
    .lightbox {
      display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(0,0,0,0.88); align-items: center; justify-content: center;
      padding: 1rem;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: min(92vw, 700px); max-height: 90vh;
      border-radius: 10px; object-fit: contain;
    }
    .lightbox-close {
      position: absolute; top: 1.2rem; right: 1.4rem;
      background: none; border: none; color: #fff; font-size: 1.8rem;
      cursor: pointer; line-height: 1; opacity: 0.75;
    }
    .lightbox-close:hover { opacity: 1; }
    @media (max-width: 760px) {
      .doorkijkje-grid { grid-template-columns: 1fr; }
    }

    /* leaders */
    .leaders-grid {
      display:grid; grid-template-columns: repeat(4, 1fr); gap: 2.8rem 1.8rem; margin-top: 2.8rem;
    }
    .leader { display:flex; flex-direction:column; align-items:center; text-align:center; }
    .leader-avatar {
      width: 130px; height: 130px; min-width: 130px; border-radius: 50%; overflow: hidden;
      flex-shrink: 0; border: 3px solid #ffffff; box-shadow: 0 2px 8px rgba(0,0,0,0.12);
      margin-bottom: 1rem;
    }
    .leader-avatar img {
      width: 100%; height: 100%; object-fit: cover; object-position: center; display:block;
    }
    .leader h3 { font-size: 1.02rem; color: var(--green-dark); margin-bottom: 0.3rem; }
    .leader-role, .leader-org {
      font-family:'Noto Sans', sans-serif; font-weight: 300;
      color: var(--text); font-size: 0.82rem; margin: 0; line-height: 1.35;
    }
    @media (max-width: 1024px) {
      .leaders-grid { grid-template-columns: 1fr 1fr; gap: 2.6rem 1.8rem; }
    }
    @media (max-width: 560px) {
      .leaders-grid { grid-template-columns: 1fr; }
    }

    /* wat we brengen */
    .brengen-head { margin-bottom: 2.4rem; }
    .brengen-head h2 { font-size: clamp(1.6rem, 3vw, 2.1rem); }
    .cards { display:grid; grid-template-columns: repeat(3, 1fr); gap: 1.8rem; }
    .card {
      border-top: 3px solid var(--green);
      padding: 1.6rem 0.2rem 0;
    }
    .card .num {
      font-family:'Jost',sans-serif; font-weight:700; font-size:1.6rem;
      color: var(--green); opacity:0.45; display:block; margin-bottom:0.6rem;
    }
    .card h3 { font-size: 1.18rem; margin-bottom: 0.6rem; }
    .card p { font-size: 0.96rem; }
    .card-link {
      display: inline-block; margin-top: 1rem; font-family:'Jost',sans-serif; font-weight:600;
      font-size: 0.82rem; letter-spacing: 0.02em; color: var(--green-dark); text-decoration:none;
      border-bottom: 1px solid var(--green); padding-bottom: 2px;
    }
    .card-link:hover { color: var(--green); }
    @media (max-width: 760px) { .cards { grid-template-columns: 1fr; gap: 2.2rem; } }

    /* wie zijn wij */
    .who-grid { display:grid; grid-template-columns: 0.85fr 1.15fr; gap: 3rem; align-items:center; }
    .who-grid img { width:100%; border-radius: 14px; display:block; }
    .who-names { font-family:'Jost',sans-serif; font-weight:600; font-size:0.85rem; letter-spacing:0.03em; color: var(--green-dark); margin-top: 0.9rem; }
    .who-names a { color: var(--green-dark); text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 1px; transition: border-color 0.15s, color 0.15s; }
    .who-names a:hover { border-color: var(--green-dark); color: var(--green); }
    .who-grid h2 { font-size: clamp(1.6rem, 3vw, 2.1rem); margin-bottom: 1.1rem; }
    .who-grid p { font-size: 1.02rem; }
    @media (max-width: 760px) { .who-grid { grid-template-columns: 1fr; } }

    footer.site {
      border-top: 1px solid var(--border); margin-top: 2rem;
      padding: 1.8rem 1.75rem 3rem; max-width: var(--max-width); margin-left:auto; margin-right:auto;
      font-family:'Jost',sans-serif; font-size: 0.82rem; color: var(--text-soft);
      display: flex; align-items: center; justify-content: space-between; gap: 1.2rem; flex-wrap: wrap;
    }
    footer.site p { margin: 0; }
    .social-links { display: flex; gap: 0.7rem; }
    .social-links a {
      display: inline-flex; align-items: center; justify-content: center;
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--bg-sage); color: var(--green-dark);
      transition: background 0.15s, color 0.15s;
    }
    .social-links a:hover { background: var(--green); color: #fff; }
  </style>

  <script>
    // Hamburger menu
    const header = document.getElementById('site-header') as HTMLElement | null;
    const toggle = header?.querySelector('.nav-toggle') as HTMLButtonElement | null;
    toggle?.addEventListener('click', () => {
      const open = header!.classList.toggle('nav-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    // Close nav when a link is clicked
    header?.querySelectorAll('.site-nav a').forEach(a => {
      a.addEventListener('click', () => {
        header.classList.remove('nav-open');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });

    // Lightbox
    const lightbox = document.getElementById('lightbox') as HTMLElement | null;
    const zoomImg = document.querySelector('.doorkijkje-img img.zoomable') as HTMLElement | null;
    const zoomHint = document.querySelector('.zoom-hint') as HTMLElement | null;
    const closeBtn = lightbox?.querySelector('.lightbox-close') as HTMLElement | null;
    function openLightbox() { lightbox?.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeLightbox() { lightbox?.classList.remove('open'); document.body.style.overflow = ''; }
    zoomImg?.addEventListener('click', openLightbox);
    zoomHint?.addEventListener('click', openLightbox);
    closeBtn?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    form?.addEventListener('submit', function (e) {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const naam = (f.elements.namedItem('naam') as HTMLInputElement).value;
      const email = (f.elements.namedItem('email') as HTMLInputElement).value;
      const bericht = (f.elements.namedItem('bericht') as HTMLTextAreaElement).value;
      const subject = encodeURIComponent('Contact via joyfulness.company — ' + naam);
      const body = encodeURIComponent('Naam: ' + naam + '\nE-mail: ' + email + '\n\n' + bericht);
      window.location.href = 'mailto:mennobraakman@joyfulness.company,johanspaans@joyfulness.world?subject=' + subject + '&body=' + body;
    });
  </script>
</Layout>
